vcpkg_from_github(
    OUT_SOURCE_PATH SOURCE_PATH
    REPO rogersce/cnpy
    REF 4e8810b1a8637695171ed346ce68f6984e585ef4
    SHA512 FA19771D4CFC31EDEBF971EA89BAF0242F2D8F2CBA57FCE0FD67E42378DA169AC9872BDF3297CA1BB96F70358B0CBC3B36DFABA8BAD9423776F75A7062CC824C
    HEAD_REF master
)

# Copy custom CMakeLists.txt and config files
file(COPY "${CMAKE_CURRENT_LIST_DIR}/CMakeLists.txt" DESTINATION "${SOURCE_PATH}")
file(COPY "${CMAKE_CURRENT_LIST_DIR}/Config.cmake.in" DESTINATION "${SOURCE_PATH}")

vcpkg_cmake_configure(
    SOURCE_PATH "${SOURCE_PATH}"
    OPTIONS
        -DENABLE_STATIC=ON
        -DENABLE_SHARED=OFF
)

vcpkg_cmake_install()

vcpkg_cmake_config_fixup(PACKAGE_NAME cnpy CONFIG_PATH lib/cmake/cnpy)

file(REMOVE_RECURSE "${CURRENT_PACKAGES_DIR}/debug/include")
file(REMOVE_RECURSE "${CURRENT_PACKAGES_DIR}/debug/share")

file(INSTALL "${SOURCE_PATH}/LICENSE" DESTINATION "${CURRENT_PACKAGES_DIR}/share/${PORT}" RENAME copyright)